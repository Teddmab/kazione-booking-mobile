# Copy to `.env` for local development (never commit real secrets).
# Valeurs équivalentes au web : même contenu que `../kazione-booking-frontends/.env` en renommant
# `VITE_SUPABASE_URL` → `EXPO_PUBLIC_SUPABASE_URL`, `VITE_SUPABASE_ANON_KEY` → `EXPO_PUBLIC_SUPABASE_ANON_KEY`, etc.
#
# Supabase local (http://127.0.0.1:54321) : OK pour navigateur sur le PC uniquement.
# Sur téléphone avec `expo start --lan`, mets l’IP LAN de ton PC (ex. http://192.168.1.42:54321), pas 127.0.0.1.
# Émulateur Android : http://10.0.2.2:54321

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_BASE_URL=https://your-project.supabase.co/functions/v1
# Stripe (Payment Sheet) — same publishable key family as the web VITE_STRIPE_PUBLISHABLE_KEY
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_SENTRY_DSN=
# L’IA (insights, analyse services, scan facture) passe par les Edge Functions backend.
# Ne pas mettre ANTHROPIC_API_KEY ici — configurer dans kazione-booking-backend/.env
